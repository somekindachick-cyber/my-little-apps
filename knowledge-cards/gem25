// --- 增强：如果 Unsplash 图片加载失败，备用分类搜索功能 ---
function getBackupImage(category) {
    const keywords = {
        "生物": "nature,biology",
        "物理": "physics,technology",
        "化学": "chemistry,lab",
        "天文": "space,galaxy",
        "地理": "earth,mountain",
        "流行": "pop-culture,cyberpunk",
        "常识": "knowledge,library"
    };
    const key = keywords[category] || "abstract";
    // 返回一个随机的分类图
    return `https://source.unsplash.com/featured/600x400?${key}&sig=${Math.random()}`;
}
    while(db.length < 50) {
        db.push({...db[db.length % 10], q: db[db.length % 10].q + " (复习题)"});
    }

    let cur = 0; let score = 0; let lock = false;

    function initGame() {
        document.getElementById('start-screen').classList.add('hidden');
        document.getElementById('game-screen').classList.remove('hidden');
        render();
    }

    function render() {
        lock = false;
        const data = db[cur];
        document.getElementById('q-text').innerText = data.q;
        document.getElementById('cat-label').innerText = `【${data.cat}】`;
        document.getElementById('prog-label').innerText = `${cur + 1} / 50`;
        document.getElementById('progress-fill').style.width = `${((cur + 1) / 50) * 100}%`;
        document.getElementById('q-img').src = data.img;

        const box = document.getElementById('opt-box');
        box.innerHTML = '';
        data.a.forEach((t, i) => {
            const b = document.createElement('button');
            b.className = 'option-btn';
            b.innerText = t;
            b.onclick = () => check(i, b);
            box.appendChild(b);
        });
    }

    function check(idx, btn) {
        if(lock) return; lock = true;
        const correct = db[cur].c;
        const btns = document.querySelectorAll('.option-btn');
        if(idx === correct) {
            btn.classList.add('correct');
            score += 2; // 每题2分，满分100
        } else {
            btn.classList.add('wrong');
            btns[correct].classList.add('correct');
        }
        setTimeout(() => {
            cur++;
            if(cur < 50) render();
            else showResult();
        }, 1200);
    }

    function showResult() {
        document.getElementById('game-screen').classList.add('hidden');
        document.getElementById('result-screen').classList.remove('hidden');
        document.getElementById('final-score').innerText = score;
        const msg = score > 80 ? "脑洞天花板！" : (score > 60 ? "知识中坚力量" : "还需要多充电哦");
        document.getElementById('rank-msg').innerText = msg;
    }

    // 图片上传实时预览逻辑
    document.getElementById('img-upload').onchange = function(e) {
        const file = e.target.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = (ev) => {
                document.getElementById('q-img').src = ev.target.result;
                db[cur].img = ev.target.result; // 保存当前题目的图
            };
            reader.readAsDataURL(file);
        }
    };
</script>
