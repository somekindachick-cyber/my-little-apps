<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>25-35岁青年跨界百科挑战</title>
    <style>
        :root {
            --primary: #8b5cf6; --bg: #030712; --card: rgba(30, 41, 59, 0.7);
            --text: #f8fafc; --success: #10b981; --error: #ef4444;
        }
        body { 
            font-family: 'PingFang SC', system-ui, sans-serif; 
            background: radial-gradient(circle at top right, #1e1b4b, #030712);
            color: var(--text); display: flex; justify-content: center; align-items: center; 
            min-height: 100vh; margin: 0; overflow-x: hidden;
        }
        #quiz-container { 
            background: var(--card); backdrop-filter: blur(12px); padding: 2rem; 
            border-radius: 2rem; width: 90%; max-width: 500px; 
            box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5); border: 1px solid rgba(255,255,255,0.1);
        }
        .img-box { 
            width: 100%; height: 200px; background: #334155; border-radius: 1.2rem; 
            margin-bottom: 1.5rem; overflow: hidden; position: relative;
            display: flex; flex-direction: column; align-items: center; justify-content: center;
        }
        .img-box img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s; }
        .upload-overlay {
            position: absolute; bottom: 10px; right: 10px; background: rgba(0,0,0,0.6);
            padding: 5px 12px; border-radius: 20px; font-size: 0.7rem; cursor: pointer; border: 1px solid #ffffff44;
        }
        .progress-bar { height: 6px; background: rgba(255,255,255,0.1); border-radius: 3px; margin: 1rem 0; }
        #progress-fill { height: 100%; background: var(--primary); width: 0%; transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1); shadow: 0 0 10px var(--primary); }
        .question-text { font-size: 1.25rem; font-weight: 600; line-height: 1.5; margin-bottom: 1.5rem; height: 4rem; }
        .options { display: grid; gap: 0.8rem; }
        .option-btn { 
            background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); 
            color: white; padding: 1rem; border-radius: 1rem; cursor: pointer; 
            text-align: left; transition: 0.2s; font-size: 1rem;
        }
        .option-btn:hover { background: rgba(255,255,255,0.15); border-color: var(--primary); }
        .correct { background: var(--success) !important; border-color: #fff; transform: scale(1.02); }
        .wrong { background: var(--error) !important; opacity: 0.8; }
        .hidden { display: none; }
        .score-num { font-size: 5rem; font-weight: 900; background: linear-gradient(to bottom, #a78bfa, #6366f1); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    </style>
</head>
<body>

<div id="quiz-container">
    <div id="start-screen" style="text-align: center;">
        <h1 style="margin-bottom: 0.5rem;">百科挑战</h1>
        <button class="option-btn" style="width: 100%; text-align: center; background: var(--primary);" onclick="initGame()">开始挑战 (50题)</button>
    </div>

    <div id="game-screen" class="hidden">
        <div style="display: flex; justify-content: space-between; font-size: 0.8rem; color: #94a3b8;">
            <span id="cat-label">分类</span>
            <span id="prog-label">1/50</span>
        </div>
        <div class="progress-bar"><div id="progress-fill"></div></div>
        
        <div class="img-box" id="img-display">
            <img id="q-img" src="" alt="题目图片">
            <label class="upload-overlay">
                📷 换图
                <input type="file" id="img-upload" hidden accept="image/*">
            </label>
        </div>

        <div class="question-text" id="q-text">加载中...</div>
        <div class="options" id="opt-box"></div>
    </div>

    <div id="result-screen" class="hidden" style="text-align: center;">
        <h2>得分报告</h2>
        <div class="score-num" id="final-score">0</div>
        <p id="rank-msg" style="font-size: 1.2rem;"></p>
        <button class="option-btn" style="margin-top: 2rem; width: 100%; text-align: center;" onclick="location.reload()">重新开启</button>
    </div>
</div>

